<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!--
        Vehicle-heavy scenario: high vehicle demand, medium pedestrian demand.
        Vehicles: ~130 (balanced was ~56, increase ~2.3x).
        Pedestrians: same as balanced (~26 peds).
        Two primary vehicle directions at period=7s, two secondary at period=9s.
    -->

    <!-- Types -->
    <vType id="car" length="5.0" maxSpeed="13.89" accel="2.6" decel="4.5"/>
    <vType id="ped" vClass="pedestrian" maxSpeed="1.2"/>

    <!-- Vehicle routes -->
    <route id="r_N2S" edges="N2C C2S"/>
    <route id="r_S2N" edges="S2C C2N"/>
    <route id="r_E2W" edges="E2C C2W"/>
    <route id="r_W2E" edges="W2C C2E"/>

    <!-- All flows sorted strictly by begin time -->

    <!-- begin=0: N->S vehicles, primary direction, period 7s (~40 vehicles) -->
    <flow id="f_N2S" type="car" route="r_N2S" begin="0" end="280" period="7"/>

    <!-- begin=5: S->N vehicles, secondary direction, period 9s (~31 vehicles) -->
    <flow id="f_S2N" type="car" route="r_S2N" begin="5" end="280" period="9"/>

    <!-- begin=10: E->W vehicles, primary direction, period 7s (~39 vehicles) -->
    <flow id="f_E2W" type="car" route="r_E2W" begin="10" end="280" period="7"/>

    <!-- begin=10: peds N->S, crossing EW arms, period 40s (~7 peds) — same as balanced -->
    <personFlow id="pf_N2S" type="ped" begin="10" end="280" period="40" departPos="180.0">
        <walk from="N2C" to="C2S"/>
    </personFlow>

    <!-- begin=15: W->E vehicles, secondary direction, period 9s (~30 vehicles) -->
    <flow id="f_W2E" type="car" route="r_W2E" begin="15" end="280" period="9"/>

    <!-- begin=15: peds W->E, crossing NS arms, period 40s (~7 peds) — same as balanced -->
    <personFlow id="pf_W2E" type="ped" begin="15" end="280" period="40" departPos="180.0">
        <walk from="W2C" to="C2E"/>
    </personFlow>

    <!-- begin=25: peds S->N, crossing EW arms, period 45s (~6 peds) — same as balanced -->
    <personFlow id="pf_S2N" type="ped" begin="25" end="280" period="45" departPos="180.0">
        <walk from="S2C" to="C2N"/>
    </personFlow>

    <!-- begin=30: peds E->W, crossing NS arms, period 45s (~6 peds) — same as balanced -->
    <personFlow id="pf_E2W" type="ped" begin="30" end="280" period="45" departPos="180.0">
        <walk from="E2C" to="C2W"/>
    </personFlow>

</routes>
