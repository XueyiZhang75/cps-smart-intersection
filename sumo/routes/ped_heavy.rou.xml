<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!--
        Ped-heavy scenario: high pedestrian demand, medium vehicle demand.
        Vehicles: same as balanced (~56 vehicles over 300s).
        Pedestrians: ~65 peds (balanced was ~26, increase ~2.5x).
        Two primary ped directions at period=15s, two secondary at period=18s.
    -->

    <!-- Types -->
    <vType id="car" length="5.0" maxSpeed="13.89" accel="2.6" decel="4.5"/>
    <vType id="ped" vClass="pedestrian" maxSpeed="1.2"/>

    <!-- Vehicle routes -->
    <route id="r_N2S" edges="N2C C2S"/>
    <route id="r_S2N" edges="S2C C2N"/>
    <route id="r_E2W" edges="E2C C2W"/>
    <route id="r_W2E" edges="W2C C2E"/>

    <!-- All flows sorted strictly by begin time -->

    <!-- begin=0: N->S vehicles, period 18s (~16 vehicles) — same as balanced -->
    <flow id="f_N2S" type="car" route="r_N2S" begin="0" end="280" period="18"/>

    <!-- begin=5: S->N vehicles, period 22s (~13 vehicles) — same as balanced -->
    <flow id="f_S2N" type="car" route="r_S2N" begin="5" end="280" period="22"/>

    <!-- begin=10: E->W vehicles, period 18s (~15 vehicles) — same as balanced -->
    <flow id="f_E2W" type="car" route="r_E2W" begin="10" end="280" period="18"/>

    <!-- begin=10: peds N->S, primary direction, period 15s (~18 peds) -->
    <personFlow id="pf_N2S" type="ped" begin="10" end="280" period="15" departPos="180.0">
        <walk from="N2C" to="C2S"/>
    </personFlow>

    <!-- begin=15: W->E vehicles, period 22s (~12 vehicles) — same as balanced -->
    <flow id="f_W2E" type="car" route="r_W2E" begin="15" end="280" period="22"/>

    <!-- begin=15: peds W->E, primary direction, period 15s (~18 peds) -->
    <personFlow id="pf_W2E" type="ped" begin="15" end="280" period="15" departPos="180.0">
        <walk from="W2C" to="C2E"/>
    </personFlow>

    <!-- begin=20: peds S->N, secondary direction, period 18s (~15 peds) -->
    <personFlow id="pf_S2N" type="ped" begin="20" end="280" period="18" departPos="180.0">
        <walk from="S2C" to="C2N"/>
    </personFlow>

    <!-- begin=25: peds E->W, secondary direction, period 18s (~14 peds) -->
    <personFlow id="pf_E2W" type="ped" begin="25" end="280" period="18" departPos="180.0">
        <walk from="E2C" to="C2W"/>
    </personFlow>

</routes>
