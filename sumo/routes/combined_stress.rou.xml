<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!--
        Combined stress (S7): directional surge base + runtime uncertainty.
        Base traffic: same as S2 directional surge (NS heavy, EW low).
        Runtime injections (via scenario YAML):
          - delay_detection (5s delay on all demand queries)
          - false_ped_request (random phantom peds on EW crossings)
        This tests the controller under simultaneous demand imbalance,
        stale observations, and false pedestrian signals.
    -->

    <!-- Types -->
    <vType id="car" length="5.0" maxSpeed="13.89" accel="2.6" decel="4.5"/>
    <vType id="ped" vClass="pedestrian" maxSpeed="1.2"/>

    <!-- Vehicle routes -->
    <route id="r_N2S" edges="N2C C2S"/>
    <route id="r_S2N" edges="S2C C2N"/>
    <route id="r_E2W" edges="E2C C2W"/>
    <route id="r_W2E" edges="W2C C2E"/>

    <!-- NS surge (same as S2) -->
    <flow id="f_N2S" type="car" route="r_N2S" begin="0" end="280" period="6"/>
    <flow id="f_S2N" type="car" route="r_S2N" begin="5" end="280" period="10"/>

    <!-- EW low (same as S2) -->
    <flow id="f_E2W" type="car" route="r_E2W" begin="10" end="280" period="25"/>

    <!-- Peds same as balanced -->
    <personFlow id="pf_N2S" type="ped" begin="10" end="280" period="40" departPos="180.0">
        <walk from="N2C" to="C2S"/>
    </personFlow>

    <flow id="f_W2E" type="car" route="r_W2E" begin="15" end="280" period="30"/>

    <personFlow id="pf_W2E" type="ped" begin="15" end="280" period="40" departPos="180.0">
        <walk from="W2C" to="C2E"/>
    </personFlow>

    <personFlow id="pf_S2N" type="ped" begin="25" end="280" period="45" departPos="180.0">
        <walk from="S2C" to="C2N"/>
    </personFlow>

    <personFlow id="pf_E2W" type="ped" begin="30" end="280" period="45" departPos="180.0">
        <walk from="E2C" to="C2W"/>
    </personFlow>

</routes>
