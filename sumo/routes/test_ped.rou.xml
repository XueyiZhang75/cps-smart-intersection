<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- Vehicle type -->
    <vType id="car" length="5.0" maxSpeed="13.89" accel="2.6" decel="4.5"/>

    <!-- Pedestrian type -->
    <vType id="ped" vClass="pedestrian" maxSpeed="1.2"/>

    <!-- Vehicle 1: North -> South (straight through) -->
    <route id="r_N2S" edges="N2C C2S"/>
    <vehicle id="veh0" type="car" route="r_N2S" depart="0.0"/>

    <!-- Vehicle 2: West -> East (straight through) -->
    <route id="r_W2E" edges="W2C C2E"/>
    <vehicle id="veh1" type="car" route="r_W2E" depart="35.0"/>

    <!-- Pedestrian 1: cross East arm (walk along N2C sidewalk -> S2C sidewalk) -->
    <person id="ped0" type="ped" depart="60.0">
        <walk from="N2C" to="S2C"/>
    </person>

    <!-- Pedestrian 2: cross North arm (walk along W2C sidewalk -> E2C sidewalk) -->
    <person id="ped1" type="ped" depart="90.0">
        <walk from="W2C" to="E2C"/>
    </person>

</routes>
